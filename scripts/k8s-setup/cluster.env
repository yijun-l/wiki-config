#!/bin/bash

# --- 1. Basic Infrastructure Info ---
NODE_USER="USERNAME"
NODE_PASSWORD="PASSWORD"

# --- 2. High Availability (HAProxy + Keepalived) Settings ---
VIP="192.168.10.10"                     # Virtual IP for K8s control plane
VIP_PORT="6443"                         # K8s API port
KEEPALIVED_AUTH_PASS="k8s_auth"         # Keepalived auth password

# --- 3. Cluster Topology ---
# Format: "IP Hostname"
MASTER_IPS=(
  "192.168.10.1 master01"
  "192.168.10.2 master02"
  "192.168.10.3 master03"
)

WORKER_IPS=(
  "192.168.20.1 worker01"
  "192.168.20.2 worker02"
)

# --- 4. Dynamic Generation Logic ---
MASTERS=()
WORKERS=()
HOSTS_ENTRIES=()
HAPROXY_BACKENDS=()
CP_ENDPOINT="${VIP}:${VIP_PORT}"

# Process Masters
for index in "${!MASTER_IPS[@]}"; do
    item="${MASTER_IPS[$index]}"
    ip=$(echo $item | awk '{print $1}')
    name=$(echo $item | awk '{print $2}')
    MASTERS+=("${NODE_USER}@${ip}")
    HOSTS_ENTRIES+=("${ip} ${name}")
    HAPROXY_BACKENDS+=("    server ${name} ${ip}:${VIP_PORT} check fall 3 rise 2")
done

# Process Workers
for item in "${WORKER_IPS[@]}"; do
    ip=$(echo $item | awk '{print $1}')
    name=$(echo $item | awk '{print $2}')
    WORKERS+=("${NODE_USER}@${ip}")
    HOSTS_ENTRIES+=("${ip} ${name}")
done

# Finalize variables
ALL_NODES=("${MASTERS[@]}" "${WORKERS[@]}")
HOSTS_BLOCK=$(printf "%s\n" "${HOSTS_ENTRIES[@]}")
HAPROXY_BACKENDS=$(printf "%s\n" "${HAPROXY_BACKENDS[@]}")
ALL_HOSTNAMES=$(printf "|%s" "${HOSTS_ENTRIES[@]}" | awk '{gsub(/ [^|]+|\\|/, ""); print substr($0,2)}')